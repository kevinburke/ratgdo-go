# Copy to secrets.yaml and fill in. secrets.yaml should be gitignored.
#
# Generate a fresh API encryption key with `make genkey`.

wifi_ssid: "your-ssid"
wifi_password: "your-wifi-password"

api_encryption_key: "base64-32-byte-key-from-make-genkey"

web_username: "admin"
web_password: "a-long-random-string"
